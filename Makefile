export PATH := $(HOME)/.local/bin:$(PATH)

##################################################################################################
# Local values
##################################################################################################
SERVICE    ?= $(notdir $(CURDIR))

##################################################################################################
# Run unit tests
##################################################################################################
.PHONY: test
test:
	@uv run pytest tests/ -v

##################################################################################################
# Ruff fix
##################################################################################################
.PHONY: ruff/fix
ruff/fix:
	@ruff check --fix .

##################################################################################################
# Ruff fix - unsafe
##################################################################################################
.PHONY: ruff/fix/unsafe
ruff/fix/unsafe:
	@ruff check --fix --unsafe-fixes .

##################################################################################################
# Sync uv
##################################################################################################
.PHONY: sync
sync:
	@uv sync --link-mode=copy
